# ============================================
# Agentic AI Tender Analyzer - Environment Config
# ============================================
# Copy this file to .env and fill in your values

# ----- AI Models -----
GROQ_API_KEY=your_groq_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here

# ----- Database -----
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/tender_analyzer
MONGODB_DB_NAME=tender_analyzer

# ----- Vector Store -----
CHROMADB_HOST=localhost
CHROMADB_PORT=8001
CHROMADB_PERSIST_DIR=./chroma_data

# ----- Search -----
GOOGLE_CSE_API_KEY=your_google_cse_api_key
GOOGLE_CSE_ID=your_custom_search_engine_id

# ----- App Config -----
BACKEND_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000
SECRET_KEY=your_secret_key_here_change_in_production
ENVIRONMENT=development

# ----- File Storage -----
UPLOAD_DIR=./uploads
REPORTS_DIR=./reports
MAX_UPLOAD_SIZE_MB=50

# ----- MCP Servers -----
PDF_MCP_PORT=8010
SEARCH_MCP_PORT=8011
DATABASE_MCP_PORT=8012
REPORT_MCP_PORT=8013
